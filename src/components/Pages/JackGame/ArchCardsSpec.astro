---
// Card variant — refined spec. Header is just icon · name · project (no transform, so
// nothing wraps/squishes). Then the files/skills created as chips, then a short blurb.
import { archLayers } from './architecture-data'

const zoneLabel: Record<string, string> = {
  app: 'The app',
  software: 'Software I wrote',
  hardware: 'Hardware I built',
  primitive: 'The primitive',
}

const icons: Record<string, string> = {
  'Jack game':
    '<rect x="3" y="7" width="18" height="11" rx="2"/><path d="M7.5 11v3M6 12.5h3"/><circle cx="16" cy="12" r=".7" fill="currentColor" stroke="none"/><circle cx="17.6" cy="14" r=".7" fill="currentColor" stroke="none"/>',
  'Jack Compiler': '<path d="M9 7l-4 5 4 5M15 7l4 5-4 5"/>',
  'VM Translator': '<path d="M12 4l8 4-8 4-8-4 8-4Z"/><path d="M4 12l8 4 8-4"/><path d="M4 16l8 4 8-4"/>',
  Assembler:
    '<rect x="5" y="5" width="5.5" height="5.5" rx="1"/><rect x="13.5" y="5" width="5.5" height="5.5" rx="1"/><rect x="5" y="13.5" width="5.5" height="5.5" rx="1"/><rect x="13.5" y="13.5" width="5.5" height="5.5" rx="1"/>',
  'Operating System':
    '<circle cx="12" cy="12" r="3.2"/><path d="M12 3v2.4M12 18.6V21M3 12h2.4M18.6 12H21M5.6 5.6l1.7 1.7M16.7 16.7l1.7 1.7M18.4 5.6l-1.7 1.7M7.3 16.7l-1.7 1.7"/>',
  Computer: '<rect x="4" y="5" width="16" height="11" rx="1.5"/><path d="M9 20h6M12 16v4"/>',
  CPU: '<rect x="7" y="7" width="10" height="10" rx="1"/><rect x="10" y="10" width="4" height="4" rx=".5"/><path d="M10 7V4.5M14 7V4.5M10 19.5V17M14 19.5V17M7 10H4.5M7 14H4.5M19.5 10H17M19.5 14H17"/>',
  'ALU · Registers · RAM': '<path d="M6 6h8l3.5 6L14 18H6l3.5-6L6 6Z"/>',
  'Logic gates': '<path d="M8 6h4a6 6 0 0 1 0 12H8V6Z"/><path d="M4 9.5h4M4 14.5h4M18 12h3"/>',
  NAND: '<path d="M7 6h4a6 6 0 0 1 0 12H7V6Z"/><path d="M3 9.5h4M3 14.5h4"/><circle cx="18.6" cy="12" r="1.4"/><path d="M20 12h3"/>',
}
---

<div class="sc">
  {
    archLayers.map((layer, i) => {
      const prev = archLayers[i - 1]
      const showZone = layer.tier !== prev?.tier
      const parts = (layer.parts ?? '').split(/,\s*/).filter(Boolean)
      return (
        <>
          {showZone && <div class="sc__zone">{zoneLabel[layer.tier]}</div>}
          <article class={`sc__card sc__card--${layer.tier}`} tabindex="0">
            <div class="sc__head">
              <span class="sc__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" set:html={icons[layer.name]} />
              </span>
              <span class="sc__title">{layer.name}</span>
              <span class="sc__rule" aria-hidden="true" />
              <span class="sc__proj">{layer.project ? `project ${layer.project}` : 'given'}</span>
            </div>

            <div class="sc__tags">
              {parts.map((p) => <span class="sc__tag">{p}</span>)}
            </div>

            <p class="sc__desc">{layer.blurb}</p>
          </article>
        </>
      )
    })
  }
</div>

<style>
  .sc {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    width: 100%;
    font-weight: 200;
  }
  .sc__zone {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.58rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin: 1.5rem 0 0.4rem;
  }
  .sc__zone:first-child {
    margin-top: 0;
  }

  .sc__card {
    width: 100%;
    padding: 0.95rem 1.1rem;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.025);
    outline: none;
    cursor: default;
    transition: border-color 0.18s ease, background 0.18s ease;
  }
  .sc__card:hover,
  .sc__card:focus {
    border-color: rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.05);
  }

  /* icon · name ———— project */
  .sc__head {
    display: flex;
    align-items: center;
    gap: 0.6rem;
  }
  .sc__icon {
    display: grid;
    place-items: center;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.7);
    flex-shrink: 0;
  }
  .sc__icon svg {
    width: 17px;
    height: 17px;
  }
  .sc__title {
    font-size: 0.95rem;
    font-weight: 500;
    color: #fff;
    white-space: nowrap;
  }
  .sc__card--primitive .sc__title {
    letter-spacing: 0.28em;
  }
  .sc__rule {
    flex: 1;
    height: 1px;
    background: rgba(255, 255, 255, 0.1);
  }
  .sc__proj {
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
    font-size: 0.6rem;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.4);
    white-space: nowrap;
    flex-shrink: 0;
  }

  .sc__tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    margin-top: 1.05rem;
  }
  .sc__tag {
    font-size: 0.68rem;
    color: rgba(255, 255, 255, 0.62);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 5px;
    padding: 0.15rem 0.45rem;
    white-space: nowrap;
  }

  .sc__desc {
    margin: 1.05rem 0 0;
    max-width: none;
    font-size: 0.78rem;
    line-height: 1.5;
    text-align: left;
    color: #b3b3b3;
  }
</style>
